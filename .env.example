# Every value here is optional - the app ships with these exact values as
# hardcoded fallbacks and runs correctly with no .env file at all. Copy to
# .env only when you need to point at something other than local defaults.

# API base path. Leave as /api to use the Vite dev proxy (same-origin, so
# CORS never applies). Set an absolute URL only for a deployed backend -
# that origin must then be listed in the backend's CORS_ALLOWED_ORIGINS.
VITE_API_BASE_URL=/api

# Where the Vite dev server proxies /api and /broadcasting.
VITE_BACKEND_URL=http://127.0.0.1:8000

# Must match the backend's REVERB_APP_KEY or the websocket handshake fails.
VITE_REVERB_APP_KEY=9ad6592ed12ea17e8d31b1c607c609cb
VITE_REVERB_HOST=127.0.0.1
VITE_REVERB_PORT=8080
VITE_REVERB_SCHEME=http
